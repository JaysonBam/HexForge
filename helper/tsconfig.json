{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "..",
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "electron"],
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "noEmitOnError": true
  },
  "include": ["src/**/*.ts", "src/**/*.cts", "../shared/**/*.ts"],
  "exclude": ["dist"]
}
